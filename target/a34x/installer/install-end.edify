
# --- Start patching firmware partitions ---

if (getprop("ro.boot.bootloader") == "A346EXXSADYG1" || getprop("ro.boot.bootloader") == "A346EXXSADYH1") then

ui_print("Detected A346EXXSADYH1 or A346EXXSADYG1 bootloader installed. Proceeding with installation");
# Camera Video Processing Unit
ui_print("Full Patching cam_vpu1-verified.img img...");
package_extract_file("firmware/A346E/cam_vpu1-verified.img", "/dev/block/by-name/cam_vpu1");

ui_print("Full Patching cam_vpu2-verified.img img...");
package_extract_file("firmware/A346E/cam_vpu2-verified.img", "/dev/block/by-name/cam_vpu2");

ui_print("Full Patching cam_vpu3-verified.img img...");
package_extract_file("firmware/A346E/cam_vpu3-verified.img", "/dev/block/by-name/cam_vpu3");

# Open BOTA
assert(mark_header_bt("/dev/block/by-name/bota", 0, 0, "000"));

# Audio Digital Signal Processing
ui_print("Write audio_dsp-verified.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A346E/audio_dsp-verified.img", "/dev/block/by-name/bota", 8, 5825616));

# Voice Wakeup
ui_print("Write scp-verified.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A346E/scp-verified.img", "/dev/block/by-name/bota", 5825660, 882800));

# DTBO
ui_print("Write dtbo.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A346E/dtbo.img", "/dev/block/by-name/bota", 6708496, 228624));

# Close BOTA
assert(mark_header_bt("/dev/block/by-name/bota", 0, 3, 3142939818));

# Vbmeta
ui_print("Full Patching vbmeta.img img...");
package_extract_file("firmware/A346E/vbmeta.img", "/dev/block/by-name/vbmeta");

else

if getprop("ro.boot.bootloader") == "A346MUBSBDYI1" then

ui_print("Detected A346MUBSBDYI1 bootloader installed. Proceeding with installation");
# Camera Video Processing Unit
ui_print("Full Patching cam_vpu1-verified.img img...");
package_extract_file("firmware/A346M/cam_vpu1-verified.img", "/dev/block/by-name/cam_vpu1");

ui_print("Full Patching cam_vpu2-verified.img img...");
package_extract_file("firmware/A346M/cam_vpu2-verified.img", "/dev/block/by-name/cam_vpu2");

ui_print("Full Patching cam_vpu3-verified.img img...");
package_extract_file("firmware/A346M/cam_vpu3-verified.img", "/dev/block/by-name/cam_vpu3");

# Open BOTA
assert(mark_header_bt("/dev/block/by-name/bota", 0, 0, "000"));

# Audio Digital Signal Processing
ui_print("Write audio_dsp-verified.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A346M/audio_dsp-verified.img", "/dev/block/by-name/bota", 8, 5825616));

# Voice Wakeup
ui_print("Write scp-verified.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A346M/scp-verified.img", "/dev/block/by-name/bota", 5825660, 882800));

# DTBO
ui_print("Write dtbo.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A346M/dtbo.img", "/dev/block/by-name/bota", 6708496, 228624));

# Close BOTA
assert(mark_header_bt("/dev/block/by-name/bota", 0, 3, 3142939818));

# Vbmeta
ui_print("Full Patching vbmeta.img img...");
package_extract_file("firmware/A346M/vbmeta.img", "/dev/block/by-name/vbmeta");

else

if getprop("ro.boot.bootloader") == "A3460ZHSADYG1" then

ui_print("Detected A3460ZHSADYG1 bootloader installed. Proceeding with installation");
# Camera Video Processing Unit
ui_print("Full Patching cam_vpu1-verified.img img...");
package_extract_file("firmware/A3460/cam_vpu1-verified.img", "/dev/block/by-name/cam_vpu1");

ui_print("Full Patching cam_vpu2-verified.img img...");
package_extract_file("firmware/A3460/cam_vpu2-verified.img", "/dev/block/by-name/cam_vpu2");

ui_print("Full Patching cam_vpu3-verified.img img...");
package_extract_file("firmware/A3460/cam_vpu3-verified.img", "/dev/block/by-name/cam_vpu3");

# Open BOTA
assert(mark_header_bt("/dev/block/by-name/bota", 0, 0, "000"));

# Audio Digital Signal Processing
ui_print("Write audio_dsp-verified.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A3460/audio_dsp-verified.img", "/dev/block/by-name/bota", 8, 5825616));

# Voice Wakeup
ui_print("Write scp-verified.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A3460/scp-verified.img", "/dev/block/by-name/bota", 5825660, 882800));

# DTBO
ui_print("Write dtbo.img to /dev/block/by-name/bota");
assert(write_data_bt("firmware/A3460/dtbo.img", "/dev/block/by-name/bota", 6708496, 229664));

# Close BOTA
assert(mark_header_bt("/dev/block/by-name/bota", 0, 3, 3142939818));

# Vbmeta
ui_print("Full Patching vbmeta.img img...");
package_extract_file("firmware/A3460/vbmeta.img", "/dev/block/by-name/vbmeta");

else

abort("E3003: This package requires the latest Android 15 firmware available for your device.");

# --- End A3460 ---
endif;

